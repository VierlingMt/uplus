# Unternehmen Plus – Basis-Härtung (Apache)

# Kein Directory-Listing
Options -Indexes

# Standard-Zeichensatz
AddDefaultCharset UTF-8

# Punkt-Dateien und sensible Endungen sperren (z.B. .ftp-deploy-sync-state.json,
# .gitignore, *.sql, *.md, config-Beispiele)
<FilesMatch "(^\.|\.(sql|md|json|lock|log|example\.php)$)">
    Require all denied
</FilesMatch>

# config.local.php niemals ausliefern (zusaetzlich zu config/.htaccess)
<Files "config.local.php">
    Require all denied
</Files>

# Einfache Security-Header
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PWA: korrekte MIME-Typen fuer Manifest & Service Worker
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>

# Startseite
DirectoryIndex index.php
